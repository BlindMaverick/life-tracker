{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npm install --prefix server"
    },
    "deploy": {
        "startCommand": "node server/migrate.js && node server/index.js",
        "restartPolicyType": "ON_FAILURE"
    }
}